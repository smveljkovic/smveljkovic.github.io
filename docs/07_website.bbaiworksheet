t\/doi\/10.4159\/9780674297074\/html\"\n          ],\n          \"image\": \"https:\/\/www.degruyterbrill.com\/document\/cover\/isbn\/9780674297074\/product_pages\",\n          \"identifier\": {\n            \"@type\": \"PropertyValue\",\n            \"propertyID\": \"DOI\",\n            \"value\": \"10.4159\/9780674297074\"\n          }\n        },\n        {\n          \"@id\": \"https:\/\/doi.org\/10.1177\/13684310241249684\",\n          \"@type\": [\n            \"ScholarlyArticle\",\n            \"Review\"\n          ],\n          \"url\": \"https:\/\/doi.org\/10.1177\/13684310241249684\",\n          \"sameAs\": [\n            \"https:\/\/journals.sagepub.com\/doi\/10.1177\/13684310241249684\"\n          ],\n          \"name\": \"Book Review: Cosmic Connections: Poetry in the Age of Disenchantment\",\n          \"headline\": \"Book Review: Cosmic Connections: Poetry in the Age of Disenchantment\",\n          \"image\": \"https:\/\/journals.sagepub.com\/cms\/asset\/e55d45ab-8419-4908-b935-0563c55874fa\/esta_28_2.cover.png\",\n          \"author\": {\n            \"@id\": \"https:\/\/orcid.org\/0000-0002-2599-3227\"\n          },\n          \"datePublished\": \"2024-05-24\",\n          \"pagination\": \"339–42\",\n          \"pageStart\": \"339\",\n          \"pageEnd\": \"342\",\n          \"itemReviewed\": {\n            \"@id\": \"https:\/\/doi.org\/10.4159\/9780674297074\"\n          },\n          \"isPartOf\": {\n            \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#issue\"\n          },\n          \"identifier\": {\n            \"@type\": \"PropertyValue\",\n            \"propertyID\": \"DOI\",\n            \"value\": \"10.1177\/13684310241249684\",\n            \"url\": \"https:\/\/doi.org\/10.1177\/13684310241249684\"\n          }\n        },\n        {\n          \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#periodical\",\n          \"@type\": \"Periodical\",\n          \"name\": \"European Journal of Social Theory\",\n          \"url\": \"https:\/\/journals.sagepub.com\/home\/EST\",\n          \"issn\": [\n            \"1368-4310\",\n            \"1461-7137\"\n          ],\n          \"publisher\": {\n            \"@type\": \"Organization\",\n            \"name\": \"Sage Publications\"\n          }\n        },\n        {\n          \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#volume\",\n          \"@type\": \"PublicationVolume\",\n          \"volumeNumber\": \"28\",\n          \"url\": \"https:\/\/journals.sagepub.com\/toc\/esta\/28\",\n          \"isPartOf\": {\n            \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#periodical\"\n          }\n        },\n        {\n          \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#issue\",\n          \"@type\": \"PublicationIssue\",\n          \"issueNumber\": \"2\",\n          \"name\": \"2\",\n          \"url\": \"https:\/\/journals.sagepub.com\/toc\/esta\/28\/2\",\n          \"datePublished\": \"2025-05\",\n          \"isPartOf\": {\n            \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#volume\"\n          }\n        },\n        {\n          \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#review\",\n          \"@type\": [\n            \"ScholarlyArticle\",\n            \"Review\"\n          ],\n          \"url\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/\",\n          \"mainEntityOfPage\": {\n            \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#webpage\"\n          },\n          \"headline\": \"Review of Cosmic Connections\",\n          \"name\": \"Review of Cosmic Connections\",\n          \"description\": \"In a book which bids fair to become his culminating output, Taylor joins up the facets of an extraordinary career.\",\n          \"version\": \"Author’s Original Manuscript\",\n          \"inLanguage\": \"en\",\n          \"author\": {\n            \"@id\": \"https:\/\/orcid.org\/0000-0002-2599-3227\"\n          },\n          \"itemReviewed\": {\n            \"@id\": \"https:\/\/doi.org\/10.4159\/9780674297074\"\n          },\n          \"isBasedOn\": {\n            \"@id\": \"https:\/\/doi.org\/10.1177\/13684310241249684\"\n          },\n          \"citation\": {\n            \"@id\": \"https:\/\/doi.org\/10.1177\/13684310241249684\"\n          },\n          \"datePublished\": \"2024-05-24T12:00:00+01:00\",\n          \"dateCreated\": \"2024-04-02T17:09:00+01:00\"\n        }\n      ]\n    }\n```\n\nHow is that looking?\n\nIt seems that the dateLabel value isn’t being used. For instance, based on something you said, I thought the idea was to use dateLabel as a name for the issue; for instance, the issue for Cosmic Connections would be called May 2025. Or did I misunderstand?","role":"user"},{"annotations":[],"content":"It is looking good overall. The main `firstPublishedOnline` distinction is now being captured correctly for the **published DOI article**:\n\n```json\n{\n  \"@id\": \"https:\/\/doi.org\/10.1177\/13684310241249684\",\n  \"datePublished\": \"2024-05-24\",\n  \"isPartOf\": {\n    \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#issue\"\n  }\n}\n```\n\nand the later issue assignment is now separately captured on the issue node:\n\n```json\n{\n  \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#issue\",\n  \"@type\": \"PublicationIssue\",\n  \"issueNumber\": \"2\",\n  \"datePublished\": \"2025-05\"\n}\n```\n\nThat is the important conceptual distinction:\n\n```text\nDOI article datePublished → first online publication date, 24 May 2024\nIssue datePublished       → issue month\/date, May 2025\n```\n\nSo the core implementation is working.\n\n## 1. Main thing to fix: local `#review` still has the old noon datetime\n\nThe DOI article node is now correct:\n\n```json\n\"datePublished\": \"2024-05-24\"\n```\n\nBut the local review node still has:\n\n```json\n\"datePublished\": \"2024-05-24T12:00:00+01:00\"\n```\n\nThis is the main remaining inconsistency.\n\nUnless noon is meaningful and verified, change the local node too:\n\n```json\n\"datePublished\": \"2024-05-24\"\n```\n\nor, if you want to be especially precise about the local manuscript being different from the DOI version, consider whether the local `#review` node should have a different publication\/upload date at all. But if it is inheriting the published review’s publication date, it should use the same date-only value:\n\n```json\n\"datePublished\": \"2024-05-24\"\n```\n\nSo: **yes, fix that one.**\n\n---\n\n## 2. The DOI article \/ issue distinction is now right\n\nThis part is good:\n\n```json\n{\n  \"@id\": \"https:\/\/doi.org\/10.1177\/13684310241249684\",\n  \"@type\": [\n    \"ScholarlyArticle\",\n    \"Review\"\n  ],\n  \"datePublished\": \"2024-05-24\",\n  \"pagination\": \"339–42\",\n  \"pageStart\": \"339\",\n  \"pageEnd\": \"342\",\n  \"isPartOf\": {\n    \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#issue\"\n  }\n}\n```\n\nand:\n\n```json\n{\n  \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#issue\",\n  \"@type\": \"PublicationIssue\",\n  \"issueNumber\": \"2\",\n  \"datePublished\": \"2025-05\",\n  \"isPartOf\": {\n    \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#volume\"\n  }\n}\n```\n\nThat says:\n\n> The review was first published online on 24 May 2024, then appeared in European Journal of Social Theory, volume 28, issue 2, May 2025, pages 339–42.\n\nThat is exactly the metadata distinction you were aiming for.\n\n---\n\n## 3. About `dateLabel`: you did not exactly misunderstand, but I would handle it carefully\n\nThere is no standard Schema.org property called:\n\n```json\n\"dateLabel\"\n```\n\nSo I would not emit this directly into JSON-LD.\n\nWhen I mentioned something like `issueDateLabel`, I meant it as an **internal\/frontmatter helper field** if you need a human-readable label such as:\n\n```text\nMay 2025\n```\n\nIt can be useful for visible display, but it does not have to appear in JSON-LD.\n\nFor JSON-LD, this is already enough:\n\n```json\n\"datePublished\": \"2025-05\"\n```\n\nA consumer can interpret that as May 2025.\n\n---\n\n## 4. Should `dateLabel` become the issue `name`?\n\nPossibly, but not necessarily.\n\nRight now you have:\n\n```json\n\"name\": \"2\"\n```\n\non the issue node:\n\n```json\n{\n  \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#issue\",\n  \"@type\": \"PublicationIssue\",\n  \"issueNumber\": \"2\",\n  \"name\": \"2\",\n  \"url\": \"https:\/\/journals.sagepub.com\/toc\/esta\/28\/2\",\n  \"datePublished\": \"2025-05\"\n}\n```\n\nI would not keep:\n\n```json\n\"name\": \"2\"\n```\n\nIt is redundant with:\n\n```json\n\"issueNumber\": \"2\"\n```\n\nand is not a meaningful name.\n\nYou have three sensible options.\n\n---\n\n### Option A: omit `name` from ordinary issue nodes\n\nThis is the simplest and probably best default:\n\n```json\n{\n  \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#issue\",\n  \"@type\": \"PublicationIssue\",\n  \"issueNumber\": \"2\",\n  \"url\": \"https:\/\/journals.sagepub.com\/toc\/esta\/28\/2\",\n  \"datePublished\": \"2025-05\",\n  \"isPartOf\": {\n    \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#volume\"\n  }\n}\n```\n\nThis is fully adequate.\n\n---\n\n### Option B: use a fuller generated issue name\n\nIf you want an issue `name`, make it descriptive rather than just `\"2\"`:\n\n```json\n\"name\": \"European Journal of Social Theory, Volume 28, Issue 2, May 2025\"\n```\n\nThis is clear and useful.\n\nThis could be generated from:\n\n```yaml\nperiodical.name: \"European Journal of Social Theory\"\nvolume: \"28\"\nissue: \"2\"\nissueDatePublished: \"2025-05\"\n```\n\nor from an explicit internal label:\n\n```yaml\nissueDateLabel: \"May 2025\"\n```\n\nThen generate:\n\n```ts\nissue.name = `${periodical.name}, Volume ${volume}, Issue ${issue}, ${issueDateLabel}`;\n```\n\n---\n\n### Option C: use `issueDateLabel` alone as issue `name`\n\nYou could set:\n\n```json\n\"name\": \"May 2025\"\n```\n\nBut I think this is less good than Option B, because “May 2025” is a date label, not really the name of the issue. It is acceptable if the publisher prominently presents the issue that way, but it is not as identifying as:\n\n```text\nEuropean Journal of Social Theory, Volume 28, Issue 2, May 2025\n```\n\n---\n\n## 5. Recommended rule for your project\n\nI would adopt this rule:\n\n```text\nissueDatePublished\n  Internal\/frontmatter field containing the machine-readable issue date,\n  e.g. 2025-05.\n\nissueDateLabel\n  Optional internal\/frontmatter field for display wording, e.g. May 2025.\n  Do not emit as dateLabel in JSON-LD.\n\nPublicationIssue.datePublished\n  Generated from issueDatePublished.\n\nPublicationIssue.name\n  Omit by default unless an explicit issue name\/title\/label is useful.\n  If present, prefer a descriptive label such as:\n  \"European Journal of Social Theory, Volume 28, Issue 2, May 2025\".\n```\n\nSo for Cosmic Connections, I would either emit no issue `name`, or emit:\n\n```json\n\"name\": \"European Journal of Social Theory, Volume 28, Issue 2, May 2025\"\n```\n\nI would not emit:\n\n```json\n\"name\": \"2\"\n```\n\n---\n\n## 6. Check whether `image` on the DOI article is really article image or issue cover\n\nYou currently have this on the DOI article node:\n\n```json\n\"image\": \"https:\/\/journals.sagepub.com\/cms\/asset\/e55d45ab-8419-4908-b935-0563c55874fa\/esta_28_2.cover.png\"\n```\n\nThat appears to be an **issue cover**, not an article-specific image.\n\nThis is not a serious problem, but if you want the model to be cleaner, move it to the `PublicationIssue` node:\n\n```json\n{\n  \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/reviews\/cosmic-connections\/#issue\",\n  \"@type\": \"PublicationIssue\",\n  \"image\": \"https:\/\/journals.sagepub.com\/cms\/asset\/e55d45ab-8419-4908-b935-0563c55874fa\/esta_28_2.cover.png\"\n}\n```\n\nFor Christian Right, you already put the issue cover on the issue node, which is cleaner.\n\nSo I would consider moving the Cosmic Connections cover image from the DOI article node to the issue node.\n\n---\n\n## 7. `sameAs` and `url` are acceptable\n\nThis is okay:\n\n```json\n\"url\": \"https:\/\/doi.org\/10.1177\/13684310241249684\",\n\"sameAs\": [\n  \"https:\/\/journals.sagepub.com\/doi\/10.1177\/13684310241249684\"\n]\n```\n\nAs before, you could alternatively use the publisher landing page as `url` and DOI as `@id`\/identifier, but the current model is acceptable.\n\n---\n\n## 8. `version: \"Author’s Original Manuscript\"` looks good\n\nThis is important for Cosmic Connections:\n\n```json\n\"version\": \"Author’s Original Manuscript\"\n```\n\nand:\n\n```json\n\"isBasedOn\": {\n  \"@id\": \"https:\/\/doi.org\/10.1177\/13684310241249684\"\n},\n\"citation\": {\n  \"@id\": \"https:\/\/doi.org\/10.1177\/13684310241249684\"\n}\n```\n\nThis preserves the key rule that the local hosted version is materially different from the published DOI version and should not use `sameAs`.\n\nThat remains good.\n\n---\n\n## Recommended immediate changes\n\nI would make these small changes before calling the `firstPublishedOnline` work complete for Cosmic Connections:\n\n1. Change local `#review` date:\n\n   ```json\n   \"datePublished\": \"2024-05-24T12:00:00+01:00\"\n   ```\n\n   to:\n\n   ```json\n   \"datePublished\": \"2024-05-24\"\n   ```\n\n2. Remove this from the issue node:\n\n   ```json\n   \"name\": \"2\"\n   ```\n\n   or replace it with:\n\n   ```json\n   \"name\": \"European Journal of Social Theory, Volume 28, Issue 2, May 2025\"\n   ```\n\n3. Consider moving the SAGE cover image from the DOI article node to the issue node.\n\nThe core structure is good. The date distinction is working. The `dateLabel` field should be treated as an internal display\/helper field, not as a direct Schema.org property; if used in JSON-LD at all, use it to help construct a meaningful `PublicationIssue.name`, not as a standalone `dateLabel`.","refusal":null,"role":"assistant"},{"content":"26 May 2026 at 16:57:11 BST\n\n# JSON-LD and moving on\n\nThis is now the JSON-LD from the \/publications\/ page\n\n```json\n{\n      \"@context\": \"https:\/\/schema.org\",\n      \"@graph\": [\n        {\n          \"@id\": \"https:\/\/stevanveljkovic.com\/#website\",\n          \"@type\": \"WebSite\",\n          \"url\": \"https:\/\/stevanveljkovic.com\/\",\n          \"name\": \"Stevan Veljkovic\",\n          \"inLanguage\": \"en-GB\",\n          \"publisher\": {\n            \"@id\": \"https:\/\/orcid.org\/0000-0002-2599-3227\"\n          }\n        },\n        {\n          \"@id\": \"https:\/\/orcid.org\/0000-0002-2599-3227\",\n          \"@type\": \"Person\",\n          \"name\": \"Stevan Veljkovic\",\n          \"url\": \"https:\/\/stevanveljkovic.com\/\",\n          \"identifier\": {\n            \"@type\": \"PropertyValue\",\n            \"propertyID\": \"ORCID\",\n            \"value\": \"0000-0002-2599-3227\",\n            \"url\": \"https:\/\/orcid.org\/0000-0002-2599-3227\"\n          },\n          \"sameAs\": [\n            \"https:\/\/orcid.org\/0000-0002-2599-3227\",\n            \"https:\/\/scholar.google.com\/citations?user=e42TN4UAAAAJ\",\n            \"https:\/\/github.com\/smveljkovic\"\n          ]\n        },\n        {\n          \"@id\": \"https:\/\/stevanveljkovic.com\/publications\/\",\n          \"@type\": \"CollectionPage\",\n          \"url\": \"https:\/\/stevanveljkovic.com\/publications\/\",\n          \"name\": \"Publications | Dr Stevan Veljkovic\",\n          \"desc