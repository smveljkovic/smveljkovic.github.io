---
import type { CollectionEntry } from "astro:content";
import { site } from "../data/site";
type ReviewData = CollectionEntry<"reviews">["data"];

const review = Astro.props.review as ReviewData;

const heading =
    review.pageHeading ??
    review.seoTitle ??
    `Review of ${review.title}`;

const firstPublishedOnline =
    review.firstPublishedOnline ??
    review.publishedReview?.firstPublishedOnline;

const showFirstPublishedOnlineNote =
    review.showFirstPublishedOnlineNote === true &&
    Boolean(firstPublishedOnline);

const formattedFirstPublishedOnline = showFirstPublishedOnlineNote
    ? new Date(firstPublishedOnline as string).toLocaleDateString("en-GB", {
      day: "numeric",
      month: "long",
      year: "numeric",
    })
    : null;

function preventFinalWordWidow(value: string): string {
  return value.replace(/\s+([^\s]+)$/, "&nbsp;$1");
}

const copyrightNotice = review.rights?.copyrightYear &&
review.rights?.copyrightHolder
    ? `© ${review.rights.copyrightYear} ${preventFinalWordWidow(review.rights.copyrightHolder.name)}.`
    : null;

const shouldGroupReuseWithRights = Boolean(review.rights?.license) || review.version === "Reproduction of the Version of Record";

const rightsParagraphHtml = [
  shouldGroupReuseWithRights ? review.reuseNoteHtml : null,
  review.modificationNote,
  copyrightNotice,
].filter(Boolean).join(" ");

---

<div>
  <div class="review_intro">
    <h1 class="review_heading">{heading}</h1>
    <p class="review_dek">By
      {site.personName} &emsp;·&emsp;
      <a href={`mailto:${site.email}`}>{site.email}</a>
    </p>

    <!--<hr class="review_intro_rule" />-->

    {review.version && (
        <p class="intro">The following text reproduces the {review.openingVersionNote ?? review.version} for</p>
    )}

    <p
        class="intro"
        style="margin-left: 2em; text-indent: -2em;"
        set:html={review.citationHtml}
    />

    {showFirstPublishedOnlineNote && (
        <p class="intro" style="margin-left: 2em">
          First published online {formattedFirstPublishedOnline}.
        </p>
    )}

    {review.reuseNoteHtml && !shouldGroupReuseWithRights && (
        <p class="intro" set:html={review.reuseNoteHtml} />
    )}

    {rightsParagraphHtml && (
        <p
            class="intro"
            style="padding-bottom: 0"
            set:html={rightsParagraphHtml}
        />
    )}
  </div>

    <style>
      .review_intro_rule {
        width: min(18rem, 58%);
        margin: 1.25rem auto 1.45rem 0;
        border: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.70);
      }
    </style>

  <div class="countercontrol">[&#8201;<a href="/publications/">previous
page</a>&#8201;]</div>

  {review.pdf && (
    <div class="control">
      <a href={review.pdf}>View as PDF</a>
    </div>
  )}
</div>