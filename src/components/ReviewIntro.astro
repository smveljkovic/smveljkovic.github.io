---
import type {CollectionEntry} from "astro:content";
import {site} from "../data/site";
type ReviewData = CollectionEntry<"reviews">["data"];

const review = Astro.props.review as ReviewData;

const heading =
    review.pageHeading ??
    review.seoTitle ??
    `Review of ${review.title}`;

const firstPublishedOnline =
    review.firstPublishedOnline ??
    review.publishedReview?.firstPublishedOnline;

const showFirstPublishedOnlineNote =
    review.showFirstPublishedOnlineNote === true &&
    Boolean(firstPublishedOnline);

const formattedFirstPublishedOnline = showFirstPublishedOnlineNote
    ? new Date(firstPublishedOnline as string).toLocaleDateString("en-GB", {
        day: "numeric",
        month: "long",
        year: "numeric",
    })
    : null;

function preventFinalWordWidow(value: string): string {
    return value.replace(/\s+([^\s]+)$/, "&nbsp;$1");
}

const copyrightNotice = review.rights?.copyrightYear &&
review.rights?.copyrightHolder?.name
    ? `© ${review.rights.copyrightYear} ${preventFinalWordWidow(review.rights.copyrightHolder.name)}.`
    : null;

const shouldGroupReuseWithRights = Boolean(review.rights?.license) || review.version === "Reproduction of the Version of Record";

const isInlineModificationNote = Boolean(
    review.modificationNote?.startsWith(" ")
);

const standaloneModificationNote = review.modificationNote && !isInlineModificationNote
    ? review.modificationNote
    : null;

const groupedReuseAndRightsHtml = [
    shouldGroupReuseWithRights ? review.reuseNoteHtml : null,
    isInlineModificationNote ? review.modificationNote : null,
    !standaloneModificationNote ? copyrightNotice : null,
].filter(Boolean).join(" ");

const standaloneCopyrightHtml = standaloneModificationNote
    ? copyrightNotice
    : null;

const isPublishedBlogPost =
    review.publishedReview?.type === "BlogPosting" ||
    review.publishedReview?.schemaTypes?.includes("BlogPosting");

const introOpeningText =
    review.introOpeningText ??
    (isPublishedBlogPost
        ? "The following text reproduces the published web article:"
        : review.version
            ? `The following text reproduces the ${
                review.openingVersionNote ?? review.version
            } for`
            : null);

const firstPublishedNoteLabel =
    review.firstPublishedNoteLabel ??
    (isPublishedBlogPost ? "First published" : "First published online");
---

<div class="review_header">
    <div class="review_intro">
        <h1 class="review_heading">{heading}</h1>
        <p class="review_dek">By{' '}
            {site.personName} &emsp;·&emsp;
            <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>

        <!--<hr class="review_intro_rule" />-->

        {introOpeningText && (
                <p class="intro">{introOpeningText}</p>
        )}

        <p
                class="intro intro_citation-main"
                set:html={review.citationHtml}
        />

        {showFirstPublishedOnlineNote && (
                <p class="intro intro_citation-note">
                    {firstPublishedNoteLabel} {formattedFirstPublishedOnline}.
                </p>
        )}

        {review.reuseNoteHtml && !shouldGroupReuseWithRights && (
                <p class="intro" set:html={review.reuseNoteHtml}/>
        )}

        {groupedReuseAndRightsHtml && (
                <p
                        class="intro"
                        style={!standaloneModificationNote && !standaloneCopyrightHtml ? "padding-bottom: 0" : undefined}
                        set:html={groupedReuseAndRightsHtml}
                />
        )}

        {standaloneModificationNote && (
                <p
                        class="intro"
                        style={!standaloneCopyrightHtml ? "padding-bottom: 0" : undefined}
                        set:html={standaloneModificationNote}
                />
        )}

        {standaloneCopyrightHtml && (
                <p
                        class="intro"
                        style="padding-bottom: 0"
                        set:html={standaloneCopyrightHtml}
                />
        )}
    </div>

    <style>
        .review_intro_rule {
            width: min(18rem, 58%);
            margin: 1.25rem auto 1.45rem 0;
            border: 0;
            border-top: 1px solid rgba(255, 255, 255, 0.70);
        }
    </style>

    <div class="countercontrol">[&#8201;<a href="/publications/">previous
        page</a>&#8201;]
    </div>

    {review.pdf && (
            <div class="control">
                <a href={review.pdf}>View as PDF</a>
            </div>
    )}
</div>
