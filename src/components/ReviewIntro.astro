---
import type { CollectionEntry } from "astro:content";

type ReviewData = CollectionEntry<"reviews">["data"];
type OriginalSubmissionNotePart = ReviewData["originalSubmissionNote"][number];

const review = Astro.props.review as ReviewData;

const heading =
    review.pageHeading ??
    review.seoTitle ??
    `Review of ${review.title}`;

const reviewedWorkShortTitle =
    review.reviewDek?.workTitle ??
    review.title;

const reviewedWorkCreatorName =
    review.reviewDek?.creatorName;

const reviewedWorkCreatorRole =
    review.reviewDek?.creatorRole ?? "author";

const reviewedWorkCreatorPhrase =
    reviewedWorkCreatorRole === "editor" ? "edited by" : "by";

const showReviewDek = Boolean(reviewedWorkCreatorName);
---

<div>
  <div class="review_intro">
    <h1 class="review_heading">{heading}</h1>

    {showReviewDek && reviewedWorkCreatorRole === "editor" && (
        <p class="review_dek">
          Stevan Veljkovic reviews <cite>{reviewedWorkShortTitle}</cite>, edited by{" "}
    {reviewedWorkCreatorName}.
          </p>
          )}

          {showReviewDek && reviewedWorkCreatorRole !== "editor" && (
              <p class="review_dek">
                Stevan Veljkovic reviews <cite>{reviewedWorkShortTitle}</cite> by{" "}
                {reviewedWorkCreatorName}.
              </p>
          )}
    <hr class="review_intro_rule" />

    <style>
      .review_intro_rule {
        width: min(18rem, 58%);
        margin: 1.25rem auto 1.45rem 0;
        border: 0;
        border-top: 1px solid rgba(255, 255, 255, 0.62);
      }
    </style>


    <p class="intro">The following text is the {review.version} for</p>

    <p class="intro" style="margin-left: 2em; text-indent: -2em;"
set:html={review.citationHtml} />

    {review.publishedReview?.datePublished && (
      <p class="intro" style="text-indent: 2em">
        First published online {new
Date(review.publishedReview.datePublished).toLocaleDateString("en-GB", {
          day: "numeric",
          month: "long",
          year: "numeric",
        })}.
      </p>
    )}

    {review.originalSubmissionNote && (
  <p class="intro">
    {review.originalSubmissionNote.map((part: OriginalSubmissionNotePart) =>
      typeof part === "string" ? (
        part
      ) : (
        <a href={part.href}>{part.text}</a>
      )
    )}
  </p>
)}

    <p class="intro" style="padding-bottom: 0">
      Errors have been corrected silently.
      <span style="white-space:nowrap">© {new
Date(review.datePublished).getFullYear()} Stevan Veljkovic</span>
    </p>
  </div>

  <div class="countercontrol">[&#8201;<a href="/publications/">previous
page</a>&#8201;]</div>

  {review.pdf && (
    <div class="control">
      <a href={review.pdf}>View as PDF</a>
    </div>
  )}
</div>