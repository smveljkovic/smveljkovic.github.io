---
import { absoluteUrl, formatTitle, site } from "../data/site";
import Analytics from "./Analytics.astro";
import FaviconLinks from "./FaviconLinks.astro";
import JsonLd from "./JsonLd.astro";

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
  image?: string;
  jsonLd?: unknown;
  bodyClass?: string;
  bodyStyle?: string;
}

const {
  title,
  description = site.description,
  canonicalPath = "/",
  ogType = "website",
  image = site.image,
  jsonLd,
} = Astro.props;

const fullTitle = formatTitle(title);

const canonicalUrl = absoluteUrl(canonicalPath);
const imageUrl = absoluteUrl(image);

const objectTitle = title ?? site.siteName;

---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="preconnect" href="https://use.typekit.net" crossorigin />
<link rel="preconnect" href="https://p.typekit.net" crossorigin />

<link
        rel="preload"
        href="/fonts/case/case-upright-var.woff2"
        as="font"
        type="font/woff2"
        crossorigin
/>

<link
        rel="preload"
        href="/fonts/case/case-italic-var.woff2"
        as="font"
        type="font/woff2"
        crossorigin
/>

<link rel="stylesheet" href="https://use.typekit.net/icu4lvx.css" />
<Analytics />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={site.author} />

<link rel="canonical" href={canonicalUrl} />

<meta property="og:title" content={objectTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:type" content={ogType} />
<meta property="og:image" content={imageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content={site.siteName} />

<meta name="twitter:title" content={objectTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:card" content="summary_large_image" />

<link rel="me" href={site.orcid} />
<link rel="me" href={site.scholar} />
<link rel="me" href={site.github} />

<FaviconLinks />

{jsonLd && <JsonLd data={jsonLd} />}