---
import BaseLayout from "./BaseLayout.astro";

const { title, description, canonicalPath, jsonLd } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
  bodyStyle="display:inline-flex; flex-direction: column; justify-content:
center; align-items: center; hyphens:manual; -webkit-font-smoothing:
antialiased; -moz-osx-font-smoothing: grayscale;">

  <slot />
</BaseLayout>