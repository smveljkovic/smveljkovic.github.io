---
import BaseLayout from "./BaseLayout.astro";
const {
    title,
    description,
    canonicalPath,
    jsonLd,
    ogType,
    image,
    } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogType={ogType}
  image={image}
  jsonLd={jsonLd}
  bodyStyle="display:inline-flex; flex-direction: column; justify-content:
center; align-items: center; hyphens:manual; -webkit-font-smoothing:
antialiased; -moz-osx-font-smoothing: grayscale;">

  <slot />

</BaseLayout>
