---
import BaseLayout from "./BaseLayout.astro";

const { title, description, canonicalPath, ogType, image, jsonLd } = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  ogType={ogType}
  image={image}
  jsonLd={jsonLd}
  bodyStyle="hyphens:manual; -webkit-font-smoothing: antialiased;
-moz-osx-font-smoothing: grayscale; display:inline-flex; flex-direction: column;
align-items: center">

  <slot />
</BaseLayout>