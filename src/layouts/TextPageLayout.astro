---
import BaseLayout from "./BaseLayout.astro";

const {title, description, canonicalPath, ogType, image, jsonLd} = Astro.props;
---

<BaseLayout
        title={title}
        description={description}
        canonicalPath={canonicalPath}
        ogType={ogType}
        image={image}
        jsonLd={jsonLd}
        bodyClass="text-page"
>
    <slot/>
</BaseLayout>