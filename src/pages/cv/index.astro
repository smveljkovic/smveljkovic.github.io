---
import TextPageLayout from "../../layouts/TextPageLayout.astro";
import {cvSchema} from "../../data/schema/cv";
import {pageMeta} from "../../data/pageMeta";

const meta = pageMeta.cv;
---

<TextPageLayout
        title={meta.title}
        description={meta.description}
        canonicalPath={meta.path}
        ogType={meta.ogType}
        jsonLd={cvSchema}>

    <div class="text-page-heading">
        <h1 class="BibHeading">Stevan Veljkovic – curriculum vitae</h1>
        <div>
            <div class="countercontrol">[&#8201;<a href="/">previous
                page</a>&#8201;]
            </div>
            <div class="control"><a href="/cv/veljkovic-cv.pdf">pdf</a> | updated May
                2026
            </div>
        </div>
    </div>

    <div class="test" id="cv">
        <p class="counter_bib">&#8239;&#8239;</p>
        <p class="CVEntry"></p>
    </div>
</TextPageLayout>
