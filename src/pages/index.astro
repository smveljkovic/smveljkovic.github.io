---
import HomeLayout from "../layouts/HomeLayout.astro";
import { homeSchema } from "../data/schema/home";
---

<HomeLayout
  title="Stevan Veljkovic – theorist and editor"
  description="Personal website of Dr Stevan Veljkovic."
  canonicalPath="/"
  jsonLd={homeSchema}>

  <div class="test">
    <header id="_idContainer001" class="Basic-Text-Frame">
      <h1 class="Name" style="color:white">Stevan Veljkovic</h1>
      <p class="Details top"><span style="white-space: nowrap">Theory and
editing</span></p>
      <p class="Details">Oxford, England</p>
    </header>

    <div id="_idContainer002" class="Basic-Text-Frame">
      <nav aria-label="Primary">
        <ul class="nav-list">
          <li>
            <p class="Headings">
              <a href="mailto:hello@stevanveljkovic.com">Contact</a>
              &nbsp;<img src="/images/Artwork_1.png" alt="" aria-hidden="true"
class="email" />
            </p>
          </li>

          <li>
            <p class="Headings">
              <a href="/cv/">Résumé</a>
              &nbsp;<img src="/images/Artwork_2.png" alt="" aria-hidden="true"
class="resume" />
            </p>
          </li>

          <li>
            <p class="Headings">
              <a href="/publications/">Writing</a>
              &nbsp;<img src="/images/Artwork_4.png" alt="" aria-hidden="true"
class="pub" />
            </p>
          </li>

          <li>
            <p class="Headings" style="padding-bottom: 1.5rem">
              <a href="https://seminars.stevanveljkovic.com/">Seminars</a>
              &nbsp;<img src="/images/Asset 1.png" alt="" aria-hidden="true"
class="pub" />
            </p>
          </li>
        </ul>

        <p class="pronunciation">
          [&NoBreak;<a
href="https://ipa-reader.com/?text=stεv(%C9%99)n&voice=Brian">pronunciation</a>:
&shy;
          <span lang="und-fonipa" style="font-family:Arial, sans-serif; white-space: nowrap;
font-size: calc(clamp(1.215rem, 4.32vmin, 1.5525rem) - 20%);">
            /ˈstεv(ə)n ˈvεlˌkəːvɪk/
          </span>&NoBreak;]
        </p>
      </nav>
    </div>
  </div>
</HomeLayout>