---
import HomeLayout from "../layouts/HomeLayout.astro";
import {homeSchema} from "../data/schema/home";
import {pageMeta} from "../data/pageMeta"

const meta = pageMeta.home;
---

<HomeLayout
        title={meta.title}
        description={meta.description}
        canonicalPath={meta.path}
        ogType={meta.ogType}
        jsonLd={homeSchema}>

    <div class="test home-card">
        <header id="_idContainer001" class="Basic-Text-Frame">
            <h1 class="Name" style="color:white">Stevan Veljkovic</h1>
            <p class="Details top">Theory and design,</p>
            <p class="Details">Oxford, England.</p>
        </header>

        <div id="_idContainer002" class="Basic-Text-Frame">
            <p class="pronunciation">
                <span class="pronunciation__lead">[<a href="/pronunciation/">pronunciation</a>:</span>
                <span
                        class="pronunciation__ipa pronunciation__ipa-part"
                        lang="und-fonipa"
                        aria-label="Stevan Veljkovic pronunciation"
                >/ˈstɛv(ə)n</span>
                <span class="pronunciation__final"><span
                        class="pronunciation__ipa pronunciation__ipa-part"
                        lang="und-fonipa"
                >ˈvɛl.kə.vɪk/</span><span class="pronunciation__lead">&#8239;]</span></span>
            </p>
        </div>
    </div>
</HomeLayout>