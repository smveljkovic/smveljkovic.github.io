---
import { getCollection } from "astro:content";
import TextPageLayout from "../../layouts/TextPageLayout.astro";
import { pageMeta } from "../../data/pageMeta";
import { createPublicationsSchema } from "../../data/schema/publications/createPublicationsSchema";

const meta = pageMeta.publications;

const reviews = await getCollection("reviews", ({ data }) => !data.draft);
const listOnlyPublicationItems = await getCollection(
    "publicationItems",
    ({ data }) => !data.draft
);

const reviewPublicationItems = reviews.map((entry) => {
    const review = entry.data;

    return {
        id: `review:${entry.id}`,
        title: review.publishedReview?.title ?? review.title,
        itemType: "bookReview" as const,
        year:
            review.publicationList?.year ??
            new Date(review.datePublished).getFullYear(),
        sortDate:
            review.publicationList?.sortDate ??
            review.publishedReview?.datePublished ??
            review.datePublished,
        order: review.publicationList?.order ?? 0,
        citationHtml: review.citationHtml,
        noteHtml: review.publicationList?.noteHtml,
        noteId: review.publicationList?.noteId,
        doi: review.publishedReview?.doi,
        url: review.publishedReview?.url,
        localPath: review.canonicalPath,
        datePublished: review.publishedReview?.datePublished ?? review.datePublished,
    };
});

const bibliographyPublicationItems = listOnlyPublicationItems.map((entry) => {
  const publicationItem = entry.data;

  return {
    id: `publicationItem:${entry.id}`,
    title: publicationItem.title,
    itemType: publicationItem.itemType,
    year: publicationItem.publicationList.year,
    sortDate: publicationItem.publicationList.sortDate ?? `${publicationItem.publicationList.year}-01-01`,
    order: publicationItem.publicationList.order ?? 0,
    citationHtml: publicationItem.citationHtml,
    noteHtml: publicationItem.publicationList.noteHtml,
    noteId: publicationItem.publicationList.noteId,
    doi: publicationItem.doi,
    url: publicationItem.url,
    datePublished: publicationItem.publicationList.sortDate,
  };
});

const publicationItems = [
    ...reviewPublicationItems,
    ...bibliographyPublicationItems,
];

const sortedPublicationItems = publicationItems.sort((a, b) => {
    if (b.year !== a.year) return b.year - a.year;

    const dateDifference =
        new Date(b.sortDate).getTime() - new Date(a.sortDate).getTime();

    if (dateDifference !== 0) return dateDifference;

    return a.order - b.order;
})

const jsonLd = createPublicationsSchema(
    sortedPublicationItems.map((item, index) => ({
      ...item,
      position: index + 1,
    }))
);

const publicationsGroups = Array.from(
    sortedPublicationItems.reduce((groups, item) => {
        const group = groups.get(item.year) ?? [];
        group.push(item);
        groups.set(item.year, group);
        return groups;
    }, new Map<number, typeof sortedPublicationItems>())
    );
---
<TextPageLayout
  title={meta.title}
  description={meta.description}
  canonicalPath={meta.path}
  ogType={meta.ogType}
  jsonLd={jsonLd}>

  <div style="display:inline-block; width:fit-content;">
    <h1 class="BibHeading">Publications and PhD thesis</h1>
    <div>
      <div class="countercontrol">[&#8201;<a href="/">previous page</a>&#8201;]</div>
      <div class="control">updated May 2026</div>
    </div>
  </div>

  <div class="test" id="writings">
      {publicationsGroups.map(([year, items]) => (
        <>
            <p class="counter_bib">&#8239;{year}&#8239;</p>

            {items.map((item) => (
                    <>
                        <p class="BibEntry" set:html={item.citationHtml} />

                        {item.noteHtml && (
                            <p
                                    class="BibEntry"
                                    id={item.noteId}
                                    set:html={item.noteHtml}
                            />
                        )}
                    </>
            ))}
        </>
       ))}
  </div>
</TextPageLayout>